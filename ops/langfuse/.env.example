# Langfuse self-hosted secrets — copy to .env and fill in before docker compose up.
# These values are only used by the Langfuse container itself; they do NOT
# need to match the VeriClaim application .env.

# Strong random strings (e.g. `openssl rand -hex 32`)
POSTGRES_PASSWORD=change_me
NEXTAUTH_SECRET=change_me
LANGFUSE_SALT=change_me
