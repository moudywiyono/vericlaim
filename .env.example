# LLM provider — set one or more; LiteLLM routes based on model name prefix
# Anthropic: model names like "claude-*"
ANTHROPIC_API_KEY=
# OpenAI: model names like "gpt-*"
OPENAI_API_KEY=
# Custom base URL — use this to point at a proxy, Azure endpoint, or local server
# e.g. http://localhost:4000 for a LiteLLM proxy, or https://api.openai.com/v1
API_BASE_URL=
# Default model for agent reasoning — used by all specialist nodes (Phase 2+)
# Prefix determines provider: "claude-*" → Anthropic, "gpt-*" → OpenAI
VERICLAIM_DEFAULT_MODEL=claude-haiku-4-5-20251001
# Model for the LLM router fallback
VERICLAIM_ROUTER_FALLBACK_MODEL=claude-haiku-4-5-20251001

# HuggingFace router
HF_ZERO_SHOT_MODEL=facebook/bart-large-mnli
# Confidence threshold below which router falls back to LLM
VERICLAIM_ROUTER_CONFIDENCE_THRESHOLD=0.5

# Langfuse tracing — leave blank to disable tracing
# Cloud: set HOST to https://cloud.langfuse.com
# Self-hosted: set HOST to http://localhost:3000 and run ops/langfuse/docker-compose.yml
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Supabase — create a free project at supabase.com
# Use the service_role key (backend only — never expose to frontend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Trace store
VERICLAIM_TRACE_DIR=traces

# Eval gates
# Set to 1 only for final reporting runs — never during development iteration
VERICLAIM_ALLOW_GOLD_EVAL=
